{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.github/hooks/check-dco.sh" },
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.github/hooks/block-dangerous.sh" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.github/hooks/validate-world.sh" }
        ]
      }
    ]
  }
}
