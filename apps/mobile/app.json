{
  "expo": {
    "name": "MUDdown",
    "slug": "muddown",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "assetBundlePatterns": ["**/*"],
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "updates": {
      "enabled": true,
      "fallbackToCacheTimeout": 0
    },
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#181a20"
    },
    "scheme": "muddown",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.muddown.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#181a20"
      },
      "package": "com.muddown.app"
    },
    "extra": {
      "serverUrl": "https://muddown.com"
    }
  }
}
