---
// Per-platform redirect to the latest desktop installer asset.
// Static SSG: at build time we look up the latest desktop release and resolve
// the right asset for each platform. If no release exists yet, we render a
// fallback that points at the Downloads page.
import Base from "../../layouts/Base.astro";

export async function getStaticPaths() {
  return [
    { params: { platform: "macos" } },
    { params: { platform: "macos-arm64" } },
    { params: { platform: "macos-x64" } },
    { params: { platform: "windows" } },
    { params: { platform: "linux" } },
    { params: { platform: "linux-appimage" } },
    { params: { platform: "linux-deb" } },
    { params: { platform: "linux-rpm" } },
  ];
}

const { platform } = Astro.params as { platform: string };

const REPO = "MUDdown/MUDdown";

type Asset = { name: string; browser_download_url: string };
type Release = { tag_name: string; assets: Asset[] };

// Two return values: a single asset for arch-specific slugs, or a pair for the
// generic /download/macos slug (so the redirect page can pick at runtime).
type Resolution =
  | { kind: "single"; url: string }
  | { kind: "macos-pair"; arm64: string | null; x64: string | null };

function pickAsset(assets: Asset[], plat: string): Asset | null {
  const by = (pred: (n: string) => boolean) =>
    assets.find((a) => pred(a.name.toLowerCase())) ?? null;

  switch (plat) {
    case "macos-arm64":
      return by((n) => n.endsWith(".dmg") && (n.includes("aarch64") || n.includes("arm64")));
    case "macos-x64":
      return (
        by((n) => n.endsWith(".dmg") && (n.includes("x64") || n.includes("x86_64"))) ??
        by((n) => n.endsWith(".dmg") && !n.includes("aarch64") && !n.includes("arm64"))
      );
    case "windows":
      return by((n) => n.endsWith(".msi")) ?? by((n) => n.endsWith(".exe"));
    case "linux":
    case "linux-appimage":
      return by((n) => n.endsWith(".appimage"));
    case "linux-deb":
      return by((n) => n.endsWith(".deb"));
    case "linux-rpm":
      return by((n) => n.endsWith(".rpm"));
    default:
      return null;
  }
}

function pickMacosPair(assets: Asset[]): { arm64: string | null; x64: string | null } {
  const by = (pred: (n: string) => boolean) =>
    assets.find((a) => pred(a.name.toLowerCase())) ?? null;
  const arm = by((n) => n.endsWith(".dmg") && (n.includes("aarch64") || n.includes("arm64")));
  const x64 = by((n) => n.endsWith(".dmg") && !n.includes("aarch64") && !n.includes("arm64"));
  return {
    arm64: arm?.browser_download_url ?? null,
    x64: x64?.browser_download_url ?? null,
  };
}

let resolution: Resolution | null = null;

try {
  const headers: Record<string, string> = {
    Accept: "application/vnd.github+json",
    "X-GitHub-Api-Version": "2022-11-28",
  };
  const token = process.env.GITHUB_TOKEN;
  if (!token) console.warn(`[download/${platform}] GITHUB_TOKEN not set; using unauthenticated API (60 req/hr limit).`);
  if (token) headers.Authorization = `Bearer ${token}`;

  const res = await fetch(`https://api.github.com/repos/${REPO}/releases?per_page=100`, { headers });
  if (res.ok) {
    const data: unknown = await res.json();
    if (!Array.isArray(data)) {
      console.warn(`[download/${platform}] GitHub API returned non-array:`, JSON.stringify(data).slice(0, 200));
    } else {
      // Only redirect to releases at v1.0.0 or later. desktop-v0.x is reserved
      // for internal verification builds and must not leak through permalinks.
      const isPublic = (tag: string | undefined): boolean =>
        !!tag && /^desktop-v[1-9]\d*\./.test(tag);
      const release = (data as Release[]).find((r) => isPublic(r.tag_name));
      if (release) {
        const assets = Array.isArray(release.assets) ? release.assets : [];
        if (platform === "macos") {
          const pair = pickMacosPair(assets);
          if (pair.arm64 || pair.x64) resolution = { kind: "macos-pair", ...pair };
        } else {
          const asset = pickAsset(assets, platform);
          if (asset) resolution = { kind: "single", url: asset.browser_download_url };
        }
      }
    }
  } else {
    const errorBody = await res.text().catch(() => "(unreadable)");
    console.warn(`[download/${platform}] GitHub API returned ${res.status}:`, errorBody.slice(0, 500));
  }
} catch (err) {
  console.warn(`[download/${platform}] GitHub API fetch failed; falling back to /download.`, err);
}

const fallback = "/download";
const singleTarget = resolution?.kind === "single" ? resolution.url : null;
const macosArm64 = resolution?.kind === "macos-pair" ? resolution.arm64 : null;
const macosX64 = resolution?.kind === "macos-pair" ? resolution.x64 : null;
const hasTarget = singleTarget !== null || macosArm64 !== null || macosX64 !== null;
const manualLink = singleTarget ?? macosArm64 ?? macosX64 ?? fallback;
---

<Base title={`Download MUDdown — ${platform}`}>
  <section class="downloads-page">
    <div class="container">
      <h2>Redirecting…</h2>
      {hasTarget ? (
        <p>
          Your download should start automatically. If it doesn't,
          <a href={manualLink}>click here</a>.
        </p>
      ) : (
        <p>
          No desktop release is available yet. Visit the <a href={fallback}>Downloads page</a>
          for status and other ways to play.
        </p>
      )}
    </div>
  </section>
</Base>

<script is:inline define:vars={{ singleTarget, macosArm64, macosX64, fallback }}>
  // For arch-specific slugs we have a single URL. For the generic /download/macos
  // slug we have both arm64 and x64 candidates and pick at runtime so Intel Macs
  // aren't sent the Apple Silicon DMG (and vice versa).
  function pickMacosTarget() {
    if (!macosArm64 && !macosX64) return fallback;
    var ua = navigator.userAgent || "";
    var uaData = navigator.userAgentData;
    var finalize = function (arch) {
      if (arch === "x64") return macosX64 || macosArm64 || fallback;
      return macosArm64 || macosX64 || fallback;
    };
    if (uaData && typeof uaData.getHighEntropyValues === "function") {
      uaData.getHighEntropyValues(["architecture"]).then(function (hints) {
        var arch = hints && hints.architecture === "x86" ? "x64" : "arm64";
        window.location.replace(finalize(arch));
      }).catch(function () {
        window.location.replace(finalize(/Intel Mac OS X/i.test(ua) ? "x64" : "arm64"));
      });
      return null; // async path takes over
    }
    return finalize(/Intel Mac OS X/i.test(ua) ? "x64" : "arm64");
  }

  if (singleTarget) {
    window.location.replace(singleTarget);
  } else if (macosArm64 || macosX64) {
    var t = pickMacosTarget();
    if (t) window.location.replace(t);
  }
</script>

<style>
  .downloads-page {
    padding: 3rem 0;
  }
</style>
