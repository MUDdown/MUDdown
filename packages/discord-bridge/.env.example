# MUDdown Discord Bridge Environment Configuration
#
# Copy to .env and fill in values: cp .env.example .env
#
# SECURITY:
# - Never commit .env. The repository's .gitignore covers .env and .env.* files.
# - The bot token is a credential. If any value below is ever pasted into git
#   history, a chat log, an issue, or a screenshot, regenerate it immediately
#   in the Discord developer portal and replace it on the host.
# - On the host, restrict the file: `chmod 600 .env && chown muddown:muddown .env`.
# - Do NOT inline the token in the systemd unit's `Environment=` lines or in
#   any shell command line; the unit reads from `EnvironmentFile=` instead.

# ─── Required ────────────────────────────────────────────────────────────────

# Discord bot token from the Developer Portal (Bot tab → Reset Token).
# Format: three base64url segments separated by dots (e.g. XXX.YYY.ZZZ).
# MUDDOWN_DISCORD_BOT_TOKEN=

# Upstream MUDdown game server WebSocket URL.
# Use ws:// when the bridge runs on the same host as the game server, or
# wss:// when the bridge connects across a network boundary.
# MUDDOWN_SERVER_URL=ws://localhost:3300

# ─── Optional ────────────────────────────────────────────────────────────────

# Discord guild (server) ID for guild-scoped slash-command registration during
# development. Slash commands appear in the named guild within seconds instead
# of the global ~1 hour propagation. Omit for production / global registration.
# MUDDOWN_DISCORD_GUILD_ID=

# Discord channel ID that receives world-scope system broadcasts (server
# boot/reboot, scheduled downtime, public events). When unset the public feed
# is disabled; per-player DM gameplay is unaffected. Per-player content is
# never sent here regardless of the value.
#
# To find the channel ID: enable Developer Mode in Discord (User Settings →
# Advanced → Developer Mode), right-click the channel, and select Copy ID.
# Format: 17–20 digits, no leading zero.
#
# Permissions required for the bot in this channel: View Channel, Send
# Messages, Embed Links. No other channel-level permissions are needed.
# MUDDOWN_DISCORD_FEED_CHANNEL_ID=

# Whether to request the privileged Message Content intent.
# Default: false. Keep this unset unless your app has Message Content enabled
# in the Discord Developer Portal and approved for your bot tier.
#
# When false, slash commands, buttons, and feed posting still work, but freeform
# text commands sent as plain DM messages are disabled.
# Accepted values: true/false, 1/0, yes/no, on/off.
# MUDDOWN_DISCORD_ENABLE_MESSAGE_CONTENT_INTENT=false

# ─── Tunables (positive integers; defaults shown) ────────────────────────────
#
# Each variable below is optional. Unset = use the default. Invalid values
# (non-numeric, zero, negative, non-integer, non-finite) cause startup to
# fail fast with a DiscordBridgeConfigError.

# Inactivity threshold before an idle DM session is evicted, in milliseconds.
# Default: 1800000 (30 minutes).
# MUDDOWN_DISCORD_IDLE_TIMEOUT_MS=1800000

# How often the idle sweep runs, in milliseconds.
# Default: 60000 (1 minute).
# MUDDOWN_DISCORD_IDLE_CHECK_INTERVAL_MS=60000

# Per-envelope retry attempts when DM delivery fails (transient Discord errors).
# Default: 3.
# MUDDOWN_DISCORD_DELIVERY_RETRIES=3

# Linear-backoff base between retries, in milliseconds.
# Effective backoff = base × attempt, capped by MAX below.
# Default: 250.
# MUDDOWN_DISCORD_DELIVERY_BACKOFF_MS=250

# Hard cap on per-attempt backoff, in milliseconds.
# Default: 5000.
# MUDDOWN_DISCORD_MAX_DELIVERY_BACKOFF_MS=5000

# Consecutive envelope-delivery failures (across separate gameplay messages)
# that terminate the session and prompt the user to reconnect via /play.
# Default: 3.
# MUDDOWN_DISCORD_MAX_CONSECUTIVE_DELIVERY_FAILURES=3
