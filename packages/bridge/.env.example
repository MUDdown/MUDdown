# MUDdown Telnet Bridge Environment Configuration
# Copy to .env and fill in values: cp .env.example .env

# ─── Core ────────────────────────────────────────────────────────────────────

# TLS listen port (default: 2323)
# BRIDGE_PORT=2323

# TLS certificate and key paths (required; the bridge is TLS-only)
# TELNET_TLS_CERT=/etc/letsencrypt/live/muddown.com/fullchain.pem
# TELNET_TLS_KEY=/etc/letsencrypt/live/muddown.com/privkey.pem

# Upstream game server WebSocket URL (default: wss://muddown.com/ws)
# GAME_SERVER_URL=wss://muddown.com/ws

# Public HTTP base URL for login links shown to remote telnet clients.
# Set this when GAME_SERVER_URL is not itself publicly reachable
# (e.g. ws://localhost:3300/ws on the same host as the game server).
# PUBLIC_BASE_URL=https://muddown.com

# Keepalive interval in ms (default: 30000)
# TELNET_KEEPALIVE_MS=30000

# Server name shown in the connection banner (default: MUDdown)
# BRIDGE_SERVER_NAME=MUDdown

# ─── MSSP (MUD Server Status Protocol, telnet option 70) ─────────────────────
#
# Static fields advertised to MUD listing crawlers and capable clients via
# the MSSP sub-negotiation. All are optional; defaults match the canonical
# MUDdown deployment. Live counts (players, rooms, etc.) are fetched from
# the game server's GET /stats endpoint and are not configurable here.
#
# The keyset mirrors the StickMUD example on the Mudlet wiki exactly
# (https://wiki.mudlet.org/w/Manual:Supported_Protocols#MSSP) — no
# additional keys are advertised.

# MSSP_NAME=MUDdown                   # defaults to BRIDGE_SERVER_NAME, then "MUDdown"
# MSSP_HOSTNAME=muddown.com
# MSSP_CONTACT=support@muddown.com
# MSSP_WEBSITE=https://muddown.com
# MSSP_ICON=https://muddown.com/favicon.ico
# MSSP_DISCORD=https://discord.gg/mDFcMT3egK
# MSSP_LANGUAGE=English
# MSSP_LOCATION=United States of America
# MSSP_CREATED=2026
# MSSP_CODEBASE=MUDdown
# MSSP_GENRE=Fantasy
# MSSP_SUBGENRE=Medieval Fantasy
# MSSP_GAMEPLAY=Hack and Slash
# MSSP_STATUS=Alpha                   # Alpha | Beta | Live
# MSSP_MINIMUM_AGE=13
