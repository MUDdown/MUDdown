{
  "name": "@muddown/client",
  "version": "0.1.0",
  "description": "Reusable MUDdown client library — renderer, connection, history, and game logic",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "FORCE_COLOR=1 vitest run",
    "test:watch": "FORCE_COLOR=1 vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@muddown/shared": "*",
    "chalk": "^5.6.2"
  },
  "license": "MIT",
  "devDependencies": {
    "vitest": "^4.1.2"
  }
}
