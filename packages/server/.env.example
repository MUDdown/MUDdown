# MUDdown Server Environment Configuration
# Copy to .env and fill in values: cp .env.example .env

# Server port (default: 3300)
PORT=3300

# SQLite database path (default: muddown.sqlite in cwd)
# MUDDOWN_DB=muddown.sqlite

# Allowed website origin for CORS (default: http://localhost:4321)
# WEBSITE_ORIGIN=https://muddown.com

# Discord OAuth (optional)
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=
# DISCORD_CALLBACK_URL=https://muddown.com/auth/callback

# GitHub OAuth (optional)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITHUB_CALLBACK_URL=https://muddown.com/auth/callback

# Microsoft OAuth (optional)
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# MICROSOFT_CALLBACK_URL=https://muddown.com/auth/callback

# Google OAuth (optional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL=https://muddown.com/auth/callback

# LLM-powered NPC dialogue (optional)
# Provider: "anthropic" (default: none — falls back to static dialogue trees)
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# Model override (default: claude-haiku-4-5-20251001)
# LLM_MODEL=claude-haiku-4-5-20251001
