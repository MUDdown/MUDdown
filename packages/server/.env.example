# MUDdown Server Environment Configuration
# Copy to .env and fill in values: cp .env.example .env

# Server port (default: 3300)
PORT=3300

# SQLite database path (default: muddown.sqlite in cwd)
# MUDDOWN_DB=muddown.sqlite

# Allowed website origin for CORS (default: http://localhost:4321)
# WEBSITE_ORIGIN=https://muddown.com

# Discord OAuth (optional)
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=
# DISCORD_CALLBACK_URL=https://muddown.com/auth/callback

# GitHub OAuth (optional)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITHUB_CALLBACK_URL=https://muddown.com/auth/callback

# Microsoft OAuth (optional)
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# MICROSOFT_CALLBACK_URL=https://muddown.com/auth/callback

# Google OAuth (optional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL=https://muddown.com/auth/callback

# LLM-powered NPC dialogue (optional)
# Provider: "anthropic" (default: none — falls back to static dialogue trees)
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# Model override (default: claude-haiku-4-5-20251001)
# LLM_MODEL=claude-haiku-4-5-20251001

# Public read-only /feed endpoint (unauthenticated; emits only scope="world").
# Caps prevent trivial socket-exhaustion DoS. See Wire-Protocol → Endpoints.
# FEED_CAP_PER_IP defaults to 8 — leaves headroom for multi-tab web clients,
# NAT'd networks (small offices, mobile carriers, university dorms), and
# bridge processes that may share an outbound IP. Increase further if you
# expect heavy reconnection churn or run behind a load balancer that
# collapses many clients to a single source IP. Set to 0 to disable the
# per-IP cap entirely (the global FEED_CAP_TOTAL still applies).
# FEED_CAP_PER_IP=8
# FEED_CAP_TOTAL=100
# FEED_PING_MS=30000
# SECURITY: Set FEED_TRUST_PROXY=1 ONLY when ALL of the following are true:
#   1. The server is behind a trusted reverse proxy (e.g. nginx, Cloudflare).
#   2. That proxy STRIPS or OVERWRITES any client-supplied X-Forwarded-For
#      header on incoming requests, then appends a single trusted client IP.
# If the proxy forwards client-supplied X-Forwarded-For values unchanged, any
# remote client can forge the header to spoof their source IP, bypassing the
# FEED_CAP_PER_IP rate/cap protections and enabling trivial DoS. When in doubt
# leave this unset — the socket peer address will be used instead.
# FEED_TRUST_PROXY=1
